{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:browser": "tsx scripts/verifyBrowserMvp.ts",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen --typecheck disable",
    "convex:deploy": "convex deploy --typecheck enable --codegen enable",
    "convex:auth-keys": "node scripts/generateConvexAuthKeys.mjs",
    "test:vercel": "tsx scripts/testVercelBuild.ts",
    "verify": "npm run lint && npm run test && npm run test:vercel"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.544.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.0.18",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.18"
  }
}
