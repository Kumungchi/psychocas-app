# Supabase — get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
MEMBERSHIP_EXPIRES_AT=2027-06-15

# Note: The VITE_ prefix is required — Vite strips any env var without it.
# The anon key is safe to expose in the browser — it's limited by Row Level Security.
# SUPABASE_SERVICE_ROLE_KEY is secret and must never be exposed in frontend code.
